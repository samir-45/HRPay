{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "artifacts/api-server/src/**",
          "lib/db/src/**",
          "lib/api-zod/src/**",
          "lib/integrations-openai-ai-server/src/**"
        ]
      }
    },
    {
      "src": "artifacts/hrpay/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/hrpay/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/hrpay/index.html"
    }
  ]
}
